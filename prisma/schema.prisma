// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "./generated"
}

datasource db {
  provider = "postgresql"
}
model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
  id            String         @id @default(cuid())
  name          String?
  email         String?        @unique
  emailVerified DateTime?
  image         String?
  accounts      Account[]
  aiUsageEvents AiUsageEvent[]
  collections    SnippetCollection[]
  sessions      Session[]
  snippets      Snippet[]
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}



model Snippet {
  id          String   @id @default(cuid())
  title       String
  code        String   @db.Text
  language    String
  public      Boolean  @default(false)
  description String?
  tags        String[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  collectionItems SnippetCollectionItem[]
  
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model SnippetCollection {
  id          String                  @id @default(cuid())
  title       String
  description String?
  accent      String                  @default("purple")
  public      Boolean                 @default(false)
  createdAt   DateTime                @default(now())
  updatedAt   DateTime                @updatedAt

  userId      String
  user        User                    @relation(fields: [userId], references: [id], onDelete: Cascade)
  items       SnippetCollectionItem[]

  @@index([userId, createdAt])
}

model SnippetCollectionItem {
  id           String             @id @default(cuid())
  collectionId String
  snippetId    String
  position     Int                @default(0)
  createdAt    DateTime           @default(now())

  collection   SnippetCollection  @relation(fields: [collectionId], references: [id], onDelete: Cascade)
  snippet      Snippet            @relation(fields: [snippetId], references: [id], onDelete: Cascade)

  @@unique([collectionId, snippetId])
  @@index([collectionId, position])
  @@index([snippetId])
}

model AiSnippetAnalysis {
  id               String         @id @default(cuid())
  codeHash         String         @unique
  model            String
  normalizedLength Int
  result           Json
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  usageEvents      AiUsageEvent[]
}

model AiUsageEvent {
  id        String            @id @default(cuid())
  userId    String
  snippetId String?
  codeHash  String
  model     String
  cacheHit  Boolean           @default(false)
  createdAt DateTime          @default(now())

  user      User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  analysis  AiSnippetAnalysis @relation(fields: [codeHash], references: [codeHash], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([codeHash])
}
