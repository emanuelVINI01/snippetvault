# SnippetVault environment variables
# Copy this file to `.env` and replace every placeholder with real values.
# Do not commit `.env` with real secrets.
#
# Next.js loads `.env*` files only from the project root.

# ---------------------------------------------------------------------------
# Database / Prisma
# ---------------------------------------------------------------------------

# Used by Prisma CLI commands, for example:
#   npx prisma migrate dev
#   npx prisma generate
#
# How to define:
# - Local PostgreSQL:
#   postgresql://postgres:postgres@localhost:5432/snippetvault
# - Hosted PostgreSQL:
#   copy the connection string from your database provider.
#
# Format:
#   postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public
DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public"

# Used by the app runtime in `src/prisma.ts` through `@prisma/adapter-pg`.
#
# How to define:
# - In local development, this can usually be the same value as DATABASE_URL.
# - In production, use the runtime connection string recommended by your
#   PostgreSQL provider. If your provider gives separate pooled/direct URLs,
#   use the URL intended for application runtime connections here.
PRISMA_DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public"

# ---------------------------------------------------------------------------
# Auth.js / NextAuth
# ---------------------------------------------------------------------------

# Secret used by Auth.js to encrypt/sign auth data.
#
# How to generate:
#   openssl rand -base64 32
#
# Alternative with Node.js:
#   node -e "console.log(crypto.randomBytes(32).toString('base64'))"
#
# Use a different value per environment. Do not reuse development secrets in
# production.
AUTH_SECRET="replace-with-output-from-openssl-rand-base64-32"

# Public base URL of the app. Auth.js can infer this in many local/dev setups,
# but setting it explicitly makes OAuth callbacks predictable.
#
# How to define:
# - Local:
#   http://localhost:3000
# - Production:
#   https://your-domain.com
#
# GitHub OAuth callback URL must be:
#   http://localhost:3000/api/auth/callback/github
# or, in production:
#   https://your-domain.com/api/auth/callback/github
AUTH_URL="http://localhost:3000"

# GitHub OAuth Client ID.
#
# How to define:
# 1. Go to GitHub > Settings > Developer settings > OAuth Apps.
# 2. Create a new OAuth App.
# 3. Set Homepage URL to your app URL, for example:
#    http://localhost:3000
# 4. Set Authorization callback URL to:
#    http://localhost:3000/api/auth/callback/github
# 5. Copy the generated Client ID.
AUTH_GITHUB_ID="replace-with-github-oauth-client-id"

# GitHub OAuth Client Secret.
#
# How to define:
# 1. In the same GitHub OAuth App, click "Generate a new client secret".
# 2. Copy the secret immediately.
# 3. Store it only in `.env` or your deployment provider secrets.
AUTH_GITHUB_SECRET="replace-with-github-oauth-client-secret"

# Optional. Useful when deploying behind a trusted proxy/platform and Auth.js
# needs to trust forwarded host headers.
#
# Common values:
# - Leave commented for normal local development.
# - Set to "true" only when your deployment environment requires it.
# AUTH_TRUST_HOST="true"

# ---------------------------------------------------------------------------
# Gemini AI
# ---------------------------------------------------------------------------

# Gemini API key used by the AI Snippet Assistant.
#
# How to define:
# 1. Create an API key in Google AI Studio.
# 2. Store it only in `.env` or your deployment provider secrets.
GEMINI_API_KEY="replace-with-gemini-api-key"

# Gemini model used for the assistant. Keep this configurable so you can switch
# models without changing code.
GEMINI_MODEL="gemini-2.5-flash"

# Daily limit of real Gemini API calls per user. Cached answers do not count
# against this number.
AI_DAILY_LIMIT="50"
